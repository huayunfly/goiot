            <div class="col-md-6">
                <figure class="figure h-100 bg-light p-2 rounded-3 shadow-sm">
                    <img src="~/img/innovation1.jpg" class="figure-img img-fluid rounded" alt="IP战略" style="aspect-ratio: 16/9; object-fit: cover;">
