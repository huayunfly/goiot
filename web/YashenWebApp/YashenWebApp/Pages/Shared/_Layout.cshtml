<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 亚申科技</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        /* 全局字体优化 */
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        }

        .hero-bg {
            background: linear-gradient(135deg, #0b132b 0%, #1c2541 50%, #3a506b 100%);
        }

        .section-card {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

            .section-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 8px 24px rgba(0,0,0,0.12);
            }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom box-shadow mb-3 sticky-top">
            <div class="container">
                <a class="navbar-brand" asp-page="/Index">
                    <img src="/img/common/yashen_logo.png" alt="亚申科技" width="34" height="32" class="me-2">
                    <span class="fw-bold d-none d-sm-inline">亚申科技</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavDropdown" aria-controls="navbarNavDropdown" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between" id="navbarNavDropdown">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">产品</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-page="/HTE">高通量设备</a></li>
                                <li><a class="dropdown-item" asp-page="/Gasifier">直接气化装置</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">产业化</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-page="/FTS">费托合成</a></li>
                                <li><a class="dropdown-item" asp-page="/SootlessDiesel">无烟柴油生产</a></li>
                                <li><a class="dropdown-item" asp-page="/DMC">柴油酯生产</a></li>
                            </ul>
                        </li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Company">公司</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/News">新闻</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Support">支持</a></li>
                    </ul>
                    <div class="d-flex align-items-center gap-2">
                        <form class="d-none d-md-flex">
                            <input class="form-control form-control-sm me-2" type="search" placeholder="搜索..." aria-label="Search" style="max-width: 180px;">
                        </form>
                        <a asp-page="/Login" class="btn btn-outline-primary btn-sm">登录</a>
                        <a asp-page="/Register" class="btn btn-primary btn-sm">注册</a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="border-top footer text-muted py-4 mt-5">
        <div class="container text-center">
            <p class="small mb-1">
                &copy; 2026 <a asp-page="/Privacy" class="text-decoration-none">亚申科技版权所有</a>
                <img src="~/img/logo01.cd7ff5et.png" alt="版权标识" style="height: 20px; margin: 0 8px; vertical-align: middle; object-fit: contain;">
                <a href="https://beian.mps.gov.cn/#/query/webSearch?code=33060302001449" target="_blank" class="text-decoration-none">浙公网安备33060302001449号</a> |
                <a href="https://beian.miit.gov.cn/#/Integrated/index" target="_blank" class="text-decoration-none">浙ICP备19034128号-1</a>
            </p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" defer></script>
    <script src="~/js/site.js" asp-append-version="true" defer></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
