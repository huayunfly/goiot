@page
@model YashenWebApp.Pages.CompanyModel
@{
    ViewData["Title"] = "公司概况";
}
<!-- 🌟 页面内容容器：自动控制左右边距，避免紧贴屏幕 -->
<div class="container py-4">

    <h1 class="display-5 fw-bold mb-4 mt-3">@ViewData["Title"]</h1>

    <!-- 公司简介 -->
    <section class="mb-5">
        <p class="lead text-muted mb-3">
            亚申科技（浙江）有限公司位于浙江省绍兴市柯桥经济开发区，由美国加州理工和硅谷、中国复旦大学、北京大学、浙江大学一批科研和工程技术人员创建发展。注册资金1.01亿元。
        </p>
        <p class="mb-4">
            亚申科技是世界领先的高通量技术专业公司。亚申自主开发，设计，建造的高通量材料开发技术平台，以比常规实验快百倍的速度，在催化剂筛选、考评、测试以及工艺研发、过程优化等方面形成了显著效率与技术优势。在数年时间里，跻身国际清洁能源百强企业，与国内外众多能源公司，科研院所建立合作关系；自主研发了多种新型催化材料、相关工艺及应用技术；申请发明专利超过210项。
        </p>
    </section>

    <!-- 企业风采 -->
    <section class="mb-5">
        <h2 class="h4 fw-semibold mb-3">企业风采</h2>
        <div class="row g-3">
            <div class="col-6 col-md-3">
                <figure class="figure h-100 bg-light p-2 rounded-3 shadow-sm">
                    <img src="~/img/company1.jpg" class="figure-img img-fluid rounded" alt="亚申大楼" style="object-fit: cover; aspect-ratio: 4/3;">
                    <figcaption class="figure-caption text-center mt-2">研发中心</figcaption>
                </figure>
            </div>
            <div class="col-6 col-md-3">
                <figure class="figure h-100 bg-light p-2 rounded-3 shadow-sm">
                    <img src="~/img/company2.jpg" class="figure-img img-fluid rounded" alt="实验研究" style="object-fit: cover; aspect-ratio: 4/3;">
                    <figcaption class="figure-caption text-center mt-2">实验分析</figcaption>
                </figure>
            </div>
            <div class="col-6 col-md-3">
                <figure class="figure h-100 bg-light p-2 rounded-3 shadow-sm">
                    <img src="~/img/company3.jpg" class="figure-img img-fluid rounded" alt="工艺开发" style="object-fit: cover; aspect-ratio: 4/3;">
                    <figcaption class="figure-caption text-center mt-2">工艺开发</figcaption>
                </figure>
            </div>
            <div class="col-6 col-md-3">
                <figure class="figure h-100 bg-light p-2 rounded-3 shadow-sm">
                    <img src="~/img/company4.jpg" class="figure-img img-fluid rounded" alt="装备建造" style="object-fit: cover; aspect-ratio: 4/3;">
                    <figcaption class="figure-caption text-center mt-2">装备建造</figcaption>
                </figure>
            </div>
        </div>
    </section>

    <!-- 核心业务 -->
    <section class="mb-5">
        <h2 class="h4 fw-semibold mb-3 text-success">核心业务</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h5 class="card-title fw-bold mb-2">先进科研装备</h5>
                        <p class="card-text text-muted mb-0">研发、设计和制造。拥有完全自主知识产权的16通道平行反应器系统是主导产品，支撑合作与自主研发，获中科院及国内外知名企业、高校广泛认可。</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h5 class="card-title fw-bold mb-2">合作研发</h5>
                        <p class="card-text text-muted mb-0">新材料新能源领域合作研发。涉及加氢催化剂、甲烷化催化剂、MTP/MTO催化剂、离子液体、储氢材料、燃料电池、分离膜技术等。</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h5 class="card-title fw-bold mb-2">自主研发</h5>
                        <p class="card-text text-muted mb-0">洁净和替代能源领域。利用高通量技术平台成功开发紧凑型费托合成、碳酸二甲酯生产、无烟柴油应用技术，前两项已完成中试并进入商业合作阶段。</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 领导团队 -->
    <section class="mb-5">
        <h2 class="h4 fw-semibold mb-3">领导团队</h2>
        <div class="row g-4">
            <div class="col-sm-6 col-lg-3">
                <div class="card h-100 border-0 shadow-sm">
                    <img src="~/img/jane.jpg" class="card-img-top" alt="权华博士" style="object-fit: cover; aspect-ratio: 1/1;">
                    <div class="card-body">
                        <h5 class="card-title fw-bold mb-1">权华 博士</h5>
                        <p class="text-primary small mb-2">总裁 / 董事长 / 创始人</p>
                        <ul class="list-unstyled small text-muted mb-0">
                            <li>• 国家特聘专家</li>
                            <li>• 20年+产品开发与项目管理经验</li>
                            <li>• 曾任Baxter、Coulter等公司技术管理职务</li>
                            <li>• 纽约州立大学化学博士，复旦学士</li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="card h-100 border-0 shadow-sm">
                    <img src="~/img/yq.jpg" class="card-img-top" alt="王尤崎博士" style="object-fit: cover; aspect-ratio: 1/1;">
                    <div class="card-body">
                        <h5 class="card-title fw-bold mb-1">王尤崎 博士</h5>
                        <p class="text-primary small mb-2">首席技术官 / 创始人</p>
                        <ul class="list-unstyled small text-muted mb-0">
                            <li>• 国家特聘专家</li>
                            <li>• 高通量技术专家</li>
                            <li>• 15项+美国专利发明人</li>
                            <li>• 加州理工学院化学博士，复旦本硕</li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="card h-100 border-0 shadow-sm">
                    <img src="~/img/steve.jpg" class="card-img-top" alt="华新雷博士" style="object-fit: cover; aspect-ratio: 1/1;">
                    <div class="card-body">
                        <h5 class="card-title fw-bold mb-1">华新雷 博士</h5>
                        <p class="text-primary small mb-2">副总裁</p>
                        <ul class="list-unstyled small text-muted mb-0">
                            <li>• 上海特聘专家</li>
                            <li>• 首航财务管理首席运营官</li>
                            <li>• Morgan Stanley 咨询顾问</li>
                            <li>• 加州理工学院物理博士，北大学士</li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="card h-100 border-0 shadow-sm">
                    <img src="~/img/xunwen.jpg" class="card-img-top" alt="王讯文" style="object-fit: cover; aspect-ratio: 1/1;">
                    <div class="card-body">
                        <h5 class="card-title fw-bold mb-1">王讯文</h5>
                        <p class="text-primary small mb-2">副总裁 / 产业化</p>
                        <ul class="list-unstyled small text-muted mb-0">
                            <li>• 20年+化工技术开发与建厂运营经验</li>
                            <li>• 成功指挥亚洲最大化工装置建设投产</li>
                            <li>• 浙江大学MBA，杭州大学化学学士</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

</div>
