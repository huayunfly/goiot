@page
@model YashenWebApp.Pages.SupportModel
@{
    ViewData["Title"] = "联系支持";
}

<div class="container py-4">
    <h1 class="display-5 fw-bold mb-4">@ViewData["Title"]</h1>

    <!-- 🖼️ 企业实景展示 -->
    <section class="mb-5">
        <div class="row g-3">
            <div class="col-md-6">
                <figure class="figure h-100 bg-light p-2 rounded-3 shadow-sm">
                    <img src="~/img/kejiyuan.jpg" class="figure-img img-fluid rounded" alt="ImgBuilding" style="object-fit: cover; aspect-ratio: 16/9;">
                    <figcaption class="figure-caption text-center mt-2">科技园</figcaption>
                </figure>
            </div>
            <div class="col-md-6">
                <figure class="figure h-100 bg-light p-2 rounded-3 shadow-sm">
                    <img src="~/img/yashenweizhi.jpg" class="figure-img img-fluid rounded" alt="ImgLocation" style="object-fit: cover; aspect-ratio: 16/9;">
                    <figcaption class="figure-caption text-center mt-2">亚申公司-G92国家高速柯桥出口500米</figcaption>
                </figure>
            </div>
        </div>
    </section>

    <!-- 📍 联系方式 -->
    <section class="mb-5">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h2 class="h4 fw-semibold mb-3">我们在这</h2>
                <ul class="list-unstyled mb-0">
                    <li class="py-2 border-bottom">
                        <span class="fw-bold text-dark">亚申科技（浙江）有限公司</span>
                    </li>
                    <li class="py-2 border-bottom d-flex align-items-start">
                        <span class="text-primary me-2 fs-5">📍</span>
                        <div>
                            <span class="d-block fw-medium">地址：浙江省绍兴市柯桥经济开发区管湖沿路68号</span>
                            <small class="text-muted">邮编：312030</small>
                        </div>
                    </li>
                    <li class="py-2 border-bottom d-flex align-items-center">
                        <span class="text-primary me-2 fs-5">📧</span>
                        <a href="mailto:shangwu@yashentech.com" class="text-decoration-none">电子邮件：shangwu@yashentech.com</a>
                    </li>
                    <li class="py-2 d-flex align-items-center">
                        <span class="text-primary me-2 fs-5">📞</span>
                        <a href="tel:0575-85666000" class="text-decoration-none">电话：575-85666000</a>
                    </li>
                </ul>
            </div>
        </div>
    </section>

    <!-- 🌐 社交媒体与快速入口 -->
    <section class="text-center py-4 bg-light rounded-3 border mb-5">
        <p class="text-muted mb-3">FollowUs</p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a href="#" class="btn btn-outline-secondary btn-sm px-3 rounded-pill">
                <span class="me-1">💬</span> WeChat
            </a>
            <a href="#" class="btn btn-outline-secondary btn-sm px-3 rounded-pill">
                <span class="me-1">🎵</span> Douyin
            </a>
            <a href="#" class="btn btn-outline-secondary btn-sm px-3 rounded-pill">
                <span class="me-1">📖</span> Zhihu
            </a>
        </div>
    </section>
</div>
