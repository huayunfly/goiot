@page
@model YashenWebApp.Pages.HTDModel
@{
    ViewData["Title"] = "高通量加速平台";
}

<!-- 📦 统一容器：解决贴边问题，控制响应式左右边距 -->
<div class="container py-4">
    <h1 class="display-5 fw-bold mb-4 mt-3">@ViewData["Title"]</h1>

    <!-- 📖 平台简介 -->
    <section class="mb-5">
        <p class="lead text-muted">
            亚申科技是世界领先的高通量技术专业公司。亚申自主开发、设计、建造的高通量材料开发技术平台，以比常规实验快百倍的速度，在催化剂筛选、考评、测试以及工艺研发、过程优化等方面形成了显著效率与技术优势。在数年时间里，跻身国际清洁能源百强企业，与国内外众多能源公司、科研院所建立合作关系；自主研发了多种新型催化材料、相关工艺及应用技术；申请发明专利超过210项。
        </p>
    </section>

    <!-- 🧪 技术特点与设备矩阵 -->
    <section class="mb-5">
        <h2 class="h4 fw-semibold mb-3 text-success">亚申科技高通量技术特点：快速、高效、系统化</h2>
        <div class="row g-3">
            <div class="col-12">
                <img src="~/img/htd1.jpg" class="img-fluid rounded shadow-sm w-100" alt="技术平台全景" style="aspect-ratio: auto; object-fit: cover;">
            </div>
            <!-- 设备缩略图网格 (修正原代码无效嵌套) -->
            <div class="col-6 col-md-4 col-lg-3">
                <img src="~/img/htd2_1.jpg" class="img-fluid rounded shadow-sm" alt="设备1" style="aspect-ratio: 4/3; object-fit: cover;">
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <img src="~/img/htd2_4.jpg" class="img-fluid rounded shadow-sm" alt="设备4" style="aspect-ratio: 4/3; object-fit: cover;">
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <img src="~/img/htd2_7.jpg" class="img-fluid rounded shadow-sm" alt="设备7" style="aspect-ratio: 4/3; object-fit: cover;">
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <img src="~/img/htd2_10.jpg" class="img-fluid rounded shadow-sm" alt="设备10" style="aspect-ratio: 4/3; object-fit: cover;">
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <img src="~/img/htd2_13.jpg" class="img-fluid rounded shadow-sm" alt="设备13" style="aspect-ratio: 4/3; object-fit: cover;">
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <img src="~/img/htd2_2.jpg" class="img-fluid rounded shadow-sm" alt="设备2" style="aspect-ratio: 4/3; object-fit: cover;">
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <img src="~/img/htd2_5.jpg" class="img-fluid rounded shadow-sm" alt="设备5" style="aspect-ratio: 4/3; object-fit: cover;">
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <img src="~/img/htd2_8.jpg" class="img-fluid rounded shadow-sm" alt="设备8" style="aspect-ratio: 4/3; object-fit: cover;">
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <img src="~/img/htd2_11.jpg" class="img-fluid rounded shadow-sm" alt="设备11" style="aspect-ratio: 4/3; object-fit: cover;">
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <img src="~/img/htd2_14.jpg" class="img-fluid rounded shadow-sm" alt="设备14" style="aspect-ratio: 4/3; object-fit: cover;">
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <img src="~/img/htd2_3.jpg" class="img-fluid rounded shadow-sm" alt="设备3" style="aspect-ratio: 4/3; object-fit: cover;">
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <img src="~/img/htd2_6.jpg" class="img-fluid rounded shadow-sm" alt="设备6" style="aspect-ratio: 4/3; object-fit: cover;">
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <img src="~/img/htd2_9.jpg" class="img-fluid rounded shadow-sm" alt="设备9" style="aspect-ratio: 4/3; object-fit: cover;">
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <img src="~/img/htd2_12.jpg" class="img-fluid rounded shadow-sm" alt="设备12" style="aspect-ratio: 4/3; object-fit: cover;">
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <img src="~/img/htd2_15.jpg" class="img-fluid rounded shadow-sm" alt="设备15" style="aspect-ratio: 4/3; object-fit: cover;">
            </div>
        </div>
    </section>

    <!-- 🔄 工艺放大与应用流程 -->
    <section class="mb-5">
        <p class="lead text-muted mb-4">
            亚申利用自主高通量技术和128通道/32通道/16通道高通量平行反应器系统，在短短几年时间里完成了费托合成等工艺的催化剂配方与制备条件筛选、本征动力学研究、成型催化剂传质研究、反应器床层内传热研究、失活老化再生处理研究以及示范装置开车流程与运行工况优化，顺利达到了可产业化水平。
        </p>
        <h2 class="h4 fw-semibold mb-3 text-success">亚申科技将高通量技术应用于研发和放大的全过程</h2>
        <div class="row g-3 align-items-center">
            <div class="col-12 col-md-6">
                <img src="~/img/htd3_1.jpg" class="img-fluid rounded shadow-sm" alt="流程1" style="aspect-ratio: 9/16; object-fit: cover;">
            </div>
            <div class="col-12 col-md-6">
                <img src="~/img/htd3_5.jpg" class="img-fluid rounded shadow-sm" alt="流程5" style="aspect-ratio: 16/9; object-fit: cover;">
            </div>
            <!-- 图文混排区域 -->
            <div class="col-12 col-md-4 d-flex align-items-center justify-content-center bg-light rounded-3 p-3">
                <p class="fw-bold text-primary mb-0 text-center">支持自顶向下、或自底向上开发</p>
            </div>
            <div class="col-12 col-md-6">
                <img src="~/img/htd3_6.jpg" class="img-fluid rounded shadow-sm" alt="流程6" style="aspect-ratio: 16/9; object-fit: cover;">
            </div>
            <div class="col-6 col-md-4">
                <img src="~/img/htd3_3.jpg" class="img-fluid rounded shadow-sm" alt="流程3" style="aspect-ratio: 4/3; object-fit: cover;">
            </div>
            <div class="col-6 col-md-4">
                <img src="~/img/htd3_7.jpg" class="img-fluid rounded shadow-sm" alt="流程7" style="aspect-ratio: 4/3; object-fit: cover;">
            </div>
            <div class="col-12 col-md-4 d-flex align-items-center justify-content-center bg-light rounded-3 p-3 order-md-last">
                <p class="fw-bold text-success mb-0 text-center">全过程工艺开发与优化</p>
            </div>
            <div class="col-6 col-md-4">
                <img src="~/img/htd3_4.jpg" class="img-fluid rounded shadow-sm" alt="流程4" style="aspect-ratio: 4/3; object-fit: cover;">
            </div>
            <div class="col-6 col-md-4">
                <img src="~/img/htd3_8.jpg" class="img-fluid rounded shadow-sm" alt="流程8" style="aspect-ratio: 4/3; object-fit: cover;">
            </div>
        </div>
    </section>

    <!-- 🤝 合作研发与自主成果 -->
    <section class="mb-5">
        <div class="row g-4">
            <div class="col-lg-6">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h3 class="h5 fw-bold mb-3 text-primary">合作研发</h3>
                        <p class="text-muted mb-0">
                            过去数年里，亚申科技基于其专有的高通量技术与合作伙伴在诸多技术领域进行了合作研发，研发领域涉及：加氢催化剂，甲烷化催化剂，MTP/MTO催化剂，离子液体，储氢材料，燃料电池，分离膜技术等。用某公司首席科学家的话说：亚申用了10个月的时间完成了他们需要50年才可以完成的试验任务。
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h3 class="h5 fw-bold mb-3 text-success">自主研发</h3>
                        <p class="text-muted mb-0">
                            亚申科技利用其特有的高通量技术平台和国际资源进行自主研发，已成功开发了费托合成和尿素醇解法生产碳酸二甲酯两项洁净能源领域新技术。在不到5年的时间里，这两个技术都已经进入中试阶段。
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
