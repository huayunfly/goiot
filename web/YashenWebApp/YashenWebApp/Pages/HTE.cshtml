@page
@model YashenWebApp.Pages.HTEModel
@{
    ViewData["Title"] = "高通量设备";
}

<!-- 🌟 页面内容容器：自动控制左右边距，避免紧贴屏幕 -->
<div class="container py-4">

    <h1 class="display-5 fw-bold mb-4 mt-3">@ViewData["Title"]</h1>
    <p class="lead text-muted mb-5">
        亚申基于其拥有完全自主知识产权的高通量平行反应设计技术，为客户定制用于催化剂测试的先进高通量系统/平台。
    </p>

    <!-- 核心设备轮播 (Bootstrap 5 语法) -->
    <section class="mb-5">
        <div id="hteCarousel" class="carousel slide rounded-3 overflow-hidden shadow" data-bs-ride="carousel">
            <div class="carousel-indicators">
                <button type="button" data-bs-target="#hteCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
                <button type="button" data-bs-target="#hteCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
                <button type="button" data-bs-target="#hteCarousel" data-bs-slide-to="2" aria-label="Slide 3"></button>
                <button type="button" data-bs-target="#hteCarousel" data-bs-slide-to="3" aria-label="Slide 4"></button>
            </div>
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <img src="~/img/hte1_3.jpg" class="d-block w-100" alt="PPSR-16系统" style="aspect-ratio: 16/9; object-fit: cover;">
                    <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded-3 p-3">
                        <h5>PPSR-16系统</h5>
                        <p>高通量 16 通道全自动平行搅拌反应釜系统</p>
                    </div>
                </div>
                <div class="carousel-item">
                    <img src="~/img/hte1_1.jpg" class="d-block w-100" alt="MPRS-16系统" style="aspect-ratio: 16/9; object-fit: cover;">
                    <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded-3 p-3">
                        <h5>MPRS-16系统</h5>
                        <p>研发级 16 通道高通量滴流床平行反应器</p>
                    </div>
                </div>
                <div class="carousel-item">
                    <img src="~/img/hte1_4.jpg" class="d-block w-100" alt="PMS-4A系统" style="aspect-ratio: 16/9; object-fit: cover;">
                    <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded-3 p-3">
                        <h5>PMS-4A系统</h5>
                        <p>高性能 4通道96样品一体化材料合成、匀化、过滤和成型系统</p>
                    </div>
                </div>
                <div class="carousel-item">
                    <img src="~/img/hte1_2.jpg" class="d-block w-100" alt="PRS-12系统" style="aspect-ratio: 16/9; object-fit: cover;">
                    <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded-3 p-3">
                        <h5>PRS-12系统</h5>
                        <p>工业级 12 通道高通量平行费托合成 / 加氢反应系统</p>
                    </div>
                </div>
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#hteCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#hteCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Next</span>
            </button>
        </div>
    </section>

    <!-- 设备优势 -->
    <section class="mb-5">
        <h2 class="h4 fw-semibold mb-3 text-success">亚申高通量设备优势</h2>
        <div class="row g-3 g-md-4">
            <div class="col-md-6 col-lg-4">
                <div class="d-flex"><span class="text-success me-2 fs-5">✓</span><div><h5 class="fw-bold mb-1">工业级应用</h5><p class="text-muted mb-0">用于工业实际应用级别的催化剂筛选和评价</p></div></div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="d-flex"><span class="text-success me-2 fs-5">✓</span><div><h5 class="fw-bold mb-1">深度研究</h5><p class="text-muted mb-0">用于反应动力学，传质传热，质量平衡，物种平衡，反应建模的研究</p></div></div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="d-flex"><span class="text-success me-2 fs-5">✓</span><div><h5 class="fw-bold mb-1">无缝集成</h5><p class="text-muted mb-0">高通量设备系统，常规设备和其他实验室仪器与软件平台的自动化无缝连接</p></div></div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="d-flex"><span class="text-success me-2 fs-5">✓</span><div><h5 class="fw-bold mb-1">安全保护</h5><p class="text-muted mb-0">集成完善的安全保护机制，可根据不同反应特点进行配置</p></div></div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="d-flex"><span class="text-success me-2 fs-5">✓</span><div><h5 class="fw-bold mb-1">数据管理</h5><p class="text-muted mb-0">搭载完全自主知识产权的商用高通量数据管理平台，支持第三方软件集成</p></div></div>
            </div>
        </div>
    </section>

    <!-- 产品图库 -->
    <section class="mb-5">
        <h2 class="h4 fw-semibold mb-3">产品图库</h2>
        <div class="row g-3">
            <div class="col-6 col-md-4 col-lg-3">
                <figure class="figure h-100"><img src="~/img/hte2_1.jpg" class="figure-img img-fluid rounded shadow-sm" alt="MRS-400微反应器"><figcaption class="figure-caption text-center mt-2 small">MRS-400微反应器</figcaption></figure>
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <figure class="figure h-100"><img src="~/img/hte2_2.jpg" class="figure-img img-fluid rounded shadow-sm" alt="PRS-16通道固定床"><figcaption class="figure-caption text-center mt-2 small">PRS-16通道固定床</figcaption></figure>
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <figure class="figure h-100"><img src="~/img/hte2_3.jpg" class="figure-img img-fluid rounded shadow-sm" alt="PRS-16串联固定床"><figcaption class="figure-caption text-center mt-2 small">PRS-16串联固定床</figcaption></figure>
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <figure class="figure h-100"><img src="~/img/hte2_4.jpg" class="figure-img img-fluid rounded shadow-sm" alt="PRS-8多用途固定床"><figcaption class="figure-caption text-center mt-2 small">PRS-8多用途固定床</figcaption></figure>
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <figure class="figure h-100"><img src="~/img/hte2_5.jpg" class="figure-img img-fluid rounded shadow-sm" alt="SRU熔盐浴固定床"><figcaption class="figure-caption text-center mt-2 small">SRU熔盐浴固定床</figcaption></figure>
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <figure class="figure h-100"><img src="~/img/hte3_1.jpg" class="figure-img img-fluid rounded shadow-sm" alt="HTMX-52混合制备系统"><figcaption class="figure-caption text-center mt-2 small">HTMX-52混合制备系统</figcaption></figure>
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <figure class="figure h-100"><img src="~/img/hte3_2.jpg" class="figure-img img-fluid rounded shadow-sm" alt="PMS-4合成制备系统"><figcaption class="figure-caption text-center mt-2 small">PMS-4合成制备系统</figcaption></figure>
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <figure class="figure h-100"><img src="~/img/hte3_5.jpg" class="figure-img img-fluid rounded shadow-sm" alt="RSC合成蜡系统"><figcaption class="figure-caption text-center mt-2 small">RSC合成蜡系统</figcaption></figure>
            </div>
        </div>
    </section>

    <!-- 企业优势 & 软件系统 -->
    <section class="mb-5">
        <div class="row g-4">
            <div class="col-lg-6">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h3 class="h4 fw-semibold text-success mb-3">亚申企业优势</h3>
                        <ul class="list-unstyled mb-0">
                            <li class="d-flex align-items-start mb-2"><span class="text-primary me-2">•</span>丰富的利用高通量装备和系统进行合作研发和自主研发的经验可以分享</li>
                            <li class="d-flex align-items-start mb-2"><span class="text-primary me-2">•</span>可以根据需求对系统进行后续的软硬件扩展开发，持续提升系统应用领域</li>
                            <li class="d-flex align-items-start mb-2"><span class="text-primary me-2">•</span>无时差，小空间距离的24小时技术咨询和技术支持</li>
                            <li class="d-flex align-items-start"><span class="text-primary me-2">•</span>可以对大批量，多批次的应用人员进行现场使用培训。</li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h3 class="h4 fw-semibold text-success mb-3">HTDMS 软件系统</h3>
                        <ul class="list-unstyled mb-0">
                            <li class="d-flex align-items-start mb-2"><span class="text-primary me-2">•</span><strong>工作流软件：</strong>图形化界面设计、修改、修正和重新布局实验运行方案</li>
                            <li class="d-flex align-items-start mb-2"><span class="text-primary me-2">•</span><strong>运行控制软件：</strong>图形化界面实现底层设备及外设在线分析设备的操作</li>
                            <li class="d-flex align-items-start"><span class="text-primary me-2">•</span><strong>数据处理软件：</strong>实时获取实验数据，计算，整合输出分析结果。</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 软件界面 -->
    <section class="mb-5">
        <h2 class="h4 fw-semibold mb-3">系统界面展示</h2>
        <div class="row g-3">
            <div class="col-md-4">
                <figure class="figure h-100"><img src="~/img/hte4_1.jpg" class="figure-img img-fluid rounded shadow-sm" alt="工作流软件系统"><figcaption class="figure-caption text-center mt-2 small">工作流软件系统</figcaption></figure>
            </div>
            <div class="col-md-4">
                <figure class="figure h-100"><img src="~/img/hte4_2.jpg" class="figure-img img-fluid rounded shadow-sm" alt="数据处理软件系统"><figcaption class="figure-caption text-center mt-2 small">数据处理软件系统</figcaption></figure>
            </div>
            <div class="col-md-4">
                <figure class="figure h-100"><img src="~/img/rz_11775280.jpg" class="figure-img img-fluid rounded shadow-sm" alt="软件著作权"><figcaption class="figure-caption text-center mt-2 small">软件著作权举例</figcaption></figure>
            </div>
        </div>
    </section>

    <!-- 外部链接引导 -->
    <section class="text-center py-4 bg-light rounded-3 border mb-5">
        <p class="mb-0 fs-5">
            欢迎访问 <a href="http://www.yashen-ht.com" target="_blank" class="fw-bold text-decoration-none">亚申高通量官网</a>，了解更多 <strong>亚申<sup>&reg;</sup> 高通量技术平台</strong> 的信息。
        </p>
    </section>
</div>
